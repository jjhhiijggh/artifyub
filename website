<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Artify UB — Vi gjør markedsføring til kunst</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
  <style>
    :root {
      --cream:#f7f3ec; --cream2:#eee9df; --white:#ffffff;
      --black:#1a1a1a; --charcoal:#2d2d2d;
      --gold:#d4923a; --gold-lt:#f0b95a;
      --coral:#e05c4b; --teal:#2aa89a; --purple:#7c5cbf;
      --blue:#3a7bd4; --green:#4caf82;
      --gray:#6b6b6b; --gray-lt:#c8c2b8;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{background:var(--cream);color:var(--charcoal);font-family:'DM Sans',sans-serif;font-weight:400;overflow-x:hidden}

    /* NAV */
    nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:1rem 4rem;background:rgba(247,243,236,0.94);backdrop-filter:blur(14px);border-bottom:1px solid rgba(212,146,58,0.18);box-shadow:0 2px 20px rgba(0,0,0,0.05)}
    .nav-logo img{height:44px;width:auto}
    .nav-links{display:flex;gap:2.2rem;list-style:none}
    .nav-links a{color:var(--gray);text-decoration:none;font-size:0.83rem;letter-spacing:0.1em;text-transform:uppercase;font-weight:500;transition:color 0.3s}
    .nav-links a:hover{color:var(--gold)}
    .nav-cta{background:var(--coral)!important;color:white!important;padding:0.5rem 1.4rem;border-radius:30px}

    /* HERO */
    .hero{min-height:100vh;background:linear-gradient(135deg,#fff8f0 0%,var(--cream) 55%,#e8f5f2 100%);display:grid;grid-template-columns:1fr 1fr;align-items:center;gap:4rem;padding:8rem 6rem 5rem;position:relative;overflow:hidden}
    .hero::before{content:'';position:absolute;top:-100px;right:-100px;width:500px;height:500px;background:radial-gradient(circle,rgba(212,146,58,0.12) 0%,transparent 70%);pointer-events:none}
    .hero::after{content:'';position:absolute;bottom:-80px;left:-80px;width:350px;height:350px;background:radial-gradient(circle,rgba(42,168,154,0.1) 0%,transparent 70%);pointer-events:none}
    .hero-text{position:relative;z-index:2}
    .hero-eyebrow{display:inline-flex;align-items:center;gap:0.6rem;background:rgba(224,92,75,0.1);color:var(--coral);font-size:0.75rem;letter-spacing:0.15em;text-transform:uppercase;padding:0.4rem 1rem;border-radius:30px;margin-bottom:1.5rem;font-weight:600;opacity:0;animation:fadeUp 0.7s 0.2s ease forwards}
    .hero h1{font-family:'Playfair Display',serif;font-size:clamp(2.8rem,5vw,4.8rem);font-weight:900;line-height:1.05;color:var(--black);margin-bottom:1.2rem;opacity:0;animation:fadeUp 0.8s 0.4s ease forwards}
    .hero h1 em{font-style:italic;color:var(--coral)}
    .hero-sub{font-size:1.05rem;color:var(--gray);line-height:1.8;max-width:480px;margin-bottom:2.5rem;opacity:0;animation:fadeUp 0.8s 0.6s ease forwards}
    .hero-btns{display:flex;gap:1rem;flex-wrap:wrap;opacity:0;animation:fadeUp 0.8s 0.8s ease forwards}
    .btn-coral{background:var(--coral);color:white;padding:0.85rem 2rem;border-radius:30px;font-size:0.88rem;font-weight:600;text-decoration:none;transition:transform 0.2s,background 0.3s;box-shadow:0 4px 18px rgba(224,92,75,0.3)}
    .btn-coral:hover{background:#c94535;transform:translateY(-2px)}
    .btn-teal{background:var(--teal);color:white;padding:0.85rem 2rem;border-radius:30px;font-size:0.88rem;font-weight:600;text-decoration:none;transition:transform 0.2s,background 0.3s;box-shadow:0 4px 18px rgba(42,168,154,0.3)}
    .btn-teal:hover{background:#228f83;transform:translateY(-2px)}
    .hero-visual{position:relative;z-index:2;opacity:0;animation:fadeUp 0.9s 0.5s ease forwards}
    .hero-visual img{width:100%;max-width:360px;display:block;margin:0 auto;filter:drop-shadow(0 20px 40px rgba(0,0,0,0.12))}
    .hero-badge{position:absolute;bottom:0px;right:10px;background:white;border-radius:14px;padding:1rem 1.2rem;box-shadow:0 8px 30px rgba(0,0,0,0.12);display:flex;align-items:center;gap:0.8rem}
    .badge-icon{font-size:1.8rem}
    .badge-text{font-size:0.75rem;color:var(--gray);line-height:1.4}
    .badge-text strong{display:block;color:var(--black);font-size:1.1rem}

    /* TICKER */
    .ticker-wrap{background:var(--coral);overflow:hidden;padding:0.9rem 0}
    .ticker{display:flex;gap:3rem;animation:ticker 22s linear infinite;white-space:nowrap}
    .ticker span{font-size:0.82rem;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;color:white}
    .ticker-dot{color:rgba(255,255,255,0.5)}

    /* STATS STRIP */
    .stats-strip{background:var(--white);padding:4rem 2rem}
    .stats-grid{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem}
    .stat-card{background:var(--cream);border-radius:18px;padding:2rem 1.5rem;text-align:center;border:1px solid rgba(0,0,0,0.05);transition:transform 0.3s,box-shadow 0.3s;position:relative}
    .stat-card:hover{transform:translateY(-6px);box-shadow:0 14px 32px rgba(0,0,0,0.09)}
    .stat-icon{font-size:2rem;margin-bottom:0.8rem}
    .stat-num{font-family:'Playfair Display',serif;font-size:2.8rem;font-weight:900;line-height:1;margin-bottom:0.3rem}
    .stat-card:nth-child(1) .stat-num{color:var(--coral)}
    .stat-card:nth-child(2) .stat-num{color:var(--teal)}
    .stat-card:nth-child(3) .stat-num{color:var(--purple)}
    .stat-card:nth-child(4) .stat-num{color:var(--gold)}
    .stat-lbl{font-size:0.82rem;color:var(--gray);line-height:1.4;font-weight:500}
    .stat-note{font-size:0.65rem;color:var(--gray-lt);margin-top:0.3rem;font-style:italic}

    /* SECTION */
    section{padding:6rem 2rem}
    .container{max-width:1100px;margin:0 auto}
    .section-pill{display:inline-block;background:rgba(212,146,58,0.13);color:var(--gold);font-size:0.72rem;letter-spacing:0.2em;text-transform:uppercase;font-weight:600;padding:0.35rem 1rem;border-radius:30px;margin-bottom:1rem}
    .section-title{font-family:'Playfair Display',serif;font-size:clamp(2rem,4vw,3.2rem);font-weight:700;line-height:1.1;margin-bottom:1.2rem;color:var(--black)}
    .section-title em{font-style:italic;color:var(--coral)}

    /* ILLUSTRATED FEATURE CARDS */
    .features{background:var(--cream2)}
    .features-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:3rem}
    .feat-card{background:white;border-radius:20px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,0.06);transition:transform 0.3s,box-shadow 0.3s}
    .feat-card:hover{transform:translateY(-6px);box-shadow:0 16px 40px rgba(0,0,0,0.1)}
    .feat-img{height:180px;display:flex;align-items:center;justify-content:center;font-size:5rem;position:relative;overflow:hidden}
    .feat-img.f1{background:linear-gradient(135deg,#ffecd2,#fcb69f)}
    .feat-img.f2{background:linear-gradient(135deg,#a1ffce,#faffd1)}
    .feat-img.f3{background:linear-gradient(135deg,#d4b8f0,#b8d4f0)}
    .feat-img.f4{background:linear-gradient(135deg,#ffd6d6,#ffd6a5)}
    .feat-img.f5{background:linear-gradient(135deg,#b5ead7,#c7ceea)}
    .feat-img.f6{background:linear-gradient(135deg,#ffdde1,#ee9ca7)}
    .feat-body{padding:1.5rem}
    .feat-body h3{font-family:'Playfair Display',serif;font-size:1.15rem;margin-bottom:0.5rem;color:var(--black)}
    .feat-body p{color:var(--gray);font-size:0.85rem;line-height:1.7}

    /* PROBLEM */
    .problem{background:var(--white)}
    .problem-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center}
    .problem-text p{color:var(--gray);line-height:1.9;margin-bottom:1.2rem;font-size:1rem}
    .stat-callout{background:var(--cream);border-left:4px solid var(--coral);padding:1.5rem 1.8rem;border-radius:0 12px 12px 0;margin:1.8rem 0;box-shadow:0 4px 20px rgba(0,0,0,0.06)}
    .stat-callout .big-num{font-family:'Playfair Display',serif;font-size:3.5rem;font-weight:900;color:var(--coral);line-height:1}
    .stat-callout p{color:var(--gray);font-size:0.9rem;margin:0.4rem 0 0}
    .challenges{display:flex;flex-direction:column;gap:1rem}
    .challenge-card{background:var(--cream);border-radius:12px;padding:1.2rem 1.5rem;display:flex;align-items:flex-start;gap:1rem;transition:transform 0.3s,box-shadow 0.3s}
    .challenge-card:hover{transform:translateX(6px);box-shadow:0 6px 24px rgba(0,0,0,0.08)}
    .ch-icon{width:44px;height:44px;border-radius:10px;display:grid;place-items:center;font-size:1.3rem;flex-shrink:0}
    .ch-icon.c1{background:rgba(224,92,75,0.12)} .ch-icon.c2{background:rgba(212,146,58,0.12)}
    .ch-icon.c3{background:rgba(42,168,154,0.12)} .ch-icon.c4{background:rgba(124,92,191,0.12)}
    .challenge-card h4{font-size:0.95rem;font-weight:600;margin-bottom:0.2rem;color:var(--black)}
    .challenge-card p{color:var(--gray);font-size:0.83rem;line-height:1.6}

    /* WHY US */
    .whyus{background:var(--cream2)}
    .whyus-inner{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center}
    .whyus-visual{background:linear-gradient(135deg,#1a1a2e,#16213e,#0f3460);border-radius:24px;padding:2.5rem;color:white;position:relative;overflow:hidden}
    .whyus-visual::before{content:'';position:absolute;top:-60px;right:-60px;width:200px;height:200px;background:radial-gradient(circle,rgba(212,146,58,0.3),transparent 70%);pointer-events:none}
    .wv-title{font-family:'Playfair Display',serif;font-size:1.5rem;margin-bottom:2rem;opacity:0.9}
    .wv-row{display:flex;justify-content:space-between;align-items:center;padding:1rem 0;border-bottom:1px solid rgba(255,255,255,0.1)}
    .wv-row:last-child{border-bottom:none}
    .wv-label{font-size:0.82rem;color:rgba(255,255,255,0.7)}
    .wv-val{font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:700;color:var(--gold-lt)}
    .wv-bar-wrap{width:100%;background:rgba(255,255,255,0.1);border-radius:4px;height:6px;margin-top:0.4rem}
    .wv-bar{height:6px;border-radius:4px;background:linear-gradient(90deg,var(--gold),var(--coral))}
    .whyus-text p{color:var(--gray);line-height:1.9;font-size:1rem;margin-bottom:1.2rem}
    .benefit-list{display:flex;flex-direction:column;gap:0.8rem;margin-top:1.5rem}
    .benefit-item{display:flex;align-items:center;gap:0.8rem;font-size:0.92rem;color:var(--charcoal)}
    .benefit-dot{width:28px;height:28px;border-radius:50%;display:grid;place-items:center;font-size:0.85rem;flex-shrink:0}
    .bd-coral{background:rgba(224,92,75,0.12);color:var(--coral)}
    .bd-teal{background:rgba(42,168,154,0.12);color:var(--teal)}
    .bd-purple{background:rgba(124,92,191,0.12);color:var(--purple)}
    .bd-gold{background:rgba(212,146,58,0.12);color:var(--gold)}

    /* RESULTS */
    .results{background:var(--white)}
    .results-inner{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start}
    .results-text p{color:var(--gray);line-height:1.9;font-size:1rem;margin-bottom:1rem}
    .big-stat-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin:1.5rem 0}
    .big-stat{background:var(--cream);border-radius:14px;padding:1.4rem;text-align:center}
    .big-stat .v{font-family:'Playfair Display',serif;font-size:2.2rem;font-weight:900;line-height:1;margin-bottom:0.2rem}
    .big-stat:nth-child(1) .v{color:var(--coral)}
    .big-stat:nth-child(2) .v{color:var(--teal)}
    .big-stat:nth-child(3) .v{color:var(--purple)}
    .big-stat:nth-child(4) .v{color:var(--gold)}
    .big-stat .l{font-size:0.75rem;color:var(--gray)}
    .platform-note{font-size:0.7rem;color:var(--gray-lt);font-style:italic;margin-top:0.5rem}

    /* PHONE MOCKUP STATS */
    .phone-mockup{background:white;border-radius:28px;padding:1.5rem;box-shadow:0 12px 40px rgba(0,0,0,0.1);border:1px solid rgba(0,0,0,0.05)}
    .phone-header{display:flex;align-items:center;gap:0.8rem;margin-bottom:1.2rem;padding-bottom:1rem;border-bottom:1px solid var(--cream2)}
    .ph-dot{width:10px;height:10px;border-radius:50%}
    .phone-title{font-size:0.78rem;font-weight:600;color:var(--charcoal);letter-spacing:0.05em}
    .phone-subtitle{font-size:0.65rem;color:var(--gray-lt)}
    .stat-block{margin-bottom:1.2rem}
    .sb-label{font-size:0.68rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--gray-lt);margin-bottom:0.4rem;font-weight:600}
    .sb-val{font-family:'Playfair Display',serif;font-size:1.8rem;font-weight:700;line-height:1;color:var(--charcoal)}
    .sb-sub{font-size:0.72rem;color:var(--gray);margin-top:0.1rem}
    .mini-bar-row{display:flex;justify-content:space-between;align-items:center;font-size:0.75rem;margin-bottom:0.3rem}
    .mini-bar-row span:first-child{color:var(--gray)}
    .mini-bar-row span:last-child{color:var(--charcoal);font-weight:600}
    .mbar{height:5px;background:var(--cream2);border-radius:3px;margin-bottom:0.7rem;overflow:hidden}
    .mbar-fill{height:5px;border-radius:3px}
    .c-coral{background:var(--coral)} .c-teal{background:var(--teal)}
    .c-purple{background:var(--purple)} .c-gold{background:var(--gold)}
    .c-blue{background:var(--blue)} .c-green{background:var(--green)}
    .divider{height:1px;background:var(--cream2);margin:1rem 0}

    /* VIDEO TABS */
    .video-section{background:var(--cream2)}
    .video-tabs{display:flex;gap:0.6rem;flex-wrap:wrap;justify-content:center;margin-bottom:2rem}
    .tab-btn{background:white;border:1.5px solid rgba(0,0,0,0.08);border-radius:30px;padding:0.5rem 1.3rem;font-family:'DM Sans',sans-serif;font-size:0.8rem;font-weight:500;color:var(--gray);cursor:pointer;transition:all 0.25s}
    .tab-btn.active{background:var(--coral);border-color:var(--coral);color:white}
    .tab-btn:hover:not(.active){border-color:var(--coral);color:var(--coral)}
    .video-panel{display:none}
    .video-panel.active{display:block}
    .vp-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;align-items:start}
    .vp-summary{background:white;border-radius:16px;padding:1.8rem;box-shadow:0 4px 20px rgba(0,0,0,0.07)}
    .vp-views{font-family:'Playfair Display',serif;font-size:3rem;font-weight:900;color:var(--coral);line-height:1;margin-bottom:0.3rem}
    .vp-meta{font-size:0.8rem;color:var(--gray);margin-bottom:1.5rem}
    .vp-kpi-grid{display:grid;grid-template-columns:1fr 1fr;gap:0.8rem;margin-bottom:1rem}
    .vp-kpi{background:var(--cream);border-radius:10px;padding:0.9rem;text-align:center}
    .vp-kpi .kv{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:var(--teal)}
    .vp-kpi .kl{font-size:0.68rem;color:var(--gray);margin-top:0.1rem}
    .vp-chart{background:white;border-radius:16px;padding:1.5rem;box-shadow:0 4px 20px rgba(0,0,0,0.07)}
    .vp-chart-title{font-size:0.72rem;text-transform:uppercase;letter-spacing:0.12em;color:var(--gray-lt);font-weight:600;margin-bottom:1rem}
    .vp-bar-row{display:flex;align-items:center;gap:0.8rem;margin-bottom:0.7rem}
    .vp-bar-label{font-size:0.75rem;color:var(--gray);width:60px;flex-shrink:0;text-align:right}
    .vp-bar-outer{flex:1;background:var(--cream2);border-radius:4px;height:8px;overflow:hidden}
    .vp-bar-inner{height:8px;border-radius:4px;background:linear-gradient(90deg,var(--coral),var(--gold-lt))}
    .vp-bar-pct{font-size:0.72rem;font-weight:600;color:var(--charcoal);width:36px;text-align:right;flex-shrink:0}
    .vp-location{background:white;border-radius:16px;padding:1.5rem;box-shadow:0 4px 20px rgba(0,0,0,0.07)}
    .vp-disclaimer{font-size:0.65rem;color:var(--gray-lt);font-style:italic;text-align:center;margin-top:1.2rem}

    /* TEAM */
    .team{background:var(--white)}
    .team-photo-wrap{border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);margin-bottom:3rem;max-height:500px}
    .team-photo-wrap img{width:100%;display:block;object-fit:contain;background:var(--cream2)}
    .team-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
    .team-card{background:var(--cream);border-radius:16px;padding:1.8rem 1.5rem;text-align:center;border:1px solid rgba(0,0,0,0.05);transition:transform 0.3s,box-shadow 0.3s}
    .team-card:hover{transform:translateY(-5px);box-shadow:0 12px 30px rgba(0,0,0,0.09)}
    .t-avatar{width:60px;height:60px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:700;color:white}
    .t1{background:linear-gradient(135deg,var(--coral),#f08070)} .t2{background:linear-gradient(135deg,var(--teal),#5dcfbf)}
    .t3{background:linear-gradient(135deg,var(--purple),#a080df)} .t4{background:linear-gradient(135deg,var(--blue),#70a0e0)}
    .t5{background:linear-gradient(135deg,var(--green),#80cfaa)} .t6{background:linear-gradient(135deg,var(--gold),#e0b870)}
    .team-card h4{font-family:'Playfair Display',serif;font-size:1rem;margin-bottom:0.3rem;color:var(--black)}
    .team-card .role{font-size:0.75rem;color:var(--gray);font-weight:500}

    /* SDG */
    .sdg{background:var(--cream2)}
    .sdg-inner{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
    .sdg-text p{color:var(--gray);line-height:1.9;font-size:1rem;margin-bottom:1rem}
    .sdg-photo{border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12)}
    .sdg-photo img{width:100%;display:block}

    /* ACHIEVEMENTS */
    .achievements{background:var(--white)}
    .achieve-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem;margin-top:3rem}
    .achieve-card{background:var(--cream);border-radius:16px;padding:1.8rem;display:flex;gap:1.2rem;align-items:flex-start;transition:transform 0.3s,box-shadow 0.3s}
    .achieve-card:hover{transform:translateY(-4px);box-shadow:0 12px 30px rgba(0,0,0,0.09)}
    .a-icon{font-size:2rem;flex-shrink:0}
    .achieve-card h4{font-family:'Playfair Display',serif;font-size:1.1rem;margin-bottom:0.4rem;color:var(--black)}
    .achieve-card p{color:var(--gray);font-size:0.85rem;line-height:1.6}
    .a-badge{display:inline-block;margin-top:0.7rem;background:rgba(224,92,75,0.1);color:var(--coral);font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase;font-weight:600;padding:0.25rem 0.8rem;border-radius:30px}

    /* CONTACT */
    .contact{background:var(--cream2)}
    .contact-inner{display:grid;grid-template-columns:1fr 1.1fr;gap:5rem;align-items:start}
    .contact-text p{color:var(--gray);line-height:1.9;font-size:1rem;margin-bottom:1.5rem}
    .contact-info{display:flex;flex-direction:column;gap:1rem;margin-top:2rem}
    .c-info-item{display:flex;align-items:center;gap:1rem;background:white;border-radius:12px;padding:1rem 1.5rem;box-shadow:0 2px 12px rgba(0,0,0,0.05)}
    .c-info-icon{font-size:1.4rem}
    .c-info-text{font-size:0.85rem;color:var(--gray)}
    .c-info-text a{color:var(--coral);text-decoration:none;font-weight:500}
    .c-info-label{font-size:0.7rem;color:var(--gray-lt);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.1rem}

    /* FORM */
    .contact-form{background:white;border-radius:20px;padding:2.5rem;box-shadow:0 8px 40px rgba(0,0,0,0.08)}
    .form-title{font-family:'Playfair Display',serif;font-size:1.5rem;margin-bottom:0.4rem;color:var(--black)}
    .form-subtitle{font-size:0.85rem;color:var(--gray);margin-bottom:1.8rem;line-height:1.5}
    .form-group{margin-bottom:1.2rem}
    .form-group label{display:block;font-size:0.75rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--charcoal);margin-bottom:0.4rem}
